{
	"compilerOptions": {
		"target": "es5" ,
		"module": "ES6",
		"rootDir": "./src",                            
		"sourceMap": true,
		"outDir": "./dist" ,
		"noEmitOnError": true,
		"baseUrl": "./",
		"paths": {
			"@/*": ["src/*"],
			"@u/*":["src/util/*"]
		},
		"moduleResolution": "node",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true
	}
}
