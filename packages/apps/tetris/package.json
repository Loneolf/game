    "build": "cross-env NODE_ENV=production rspack build --config ./rspack.config.js && pnpm upLoad",
    "testUpload": "cross-env NODE_ENV=test node ./src/util/upCDN.js",
    "upLoad": "node ./src/util/upCDN.js"
  },
