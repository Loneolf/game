{
  "name": "@qgame/tetris",
  "version": "1.0.0",
  "description": "俄罗斯方块游戏",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "pnpm serve",
    "start": "pnpm serve",
    "serve": "cross-env NODE_ENV=development rspack serve --config ./rspack.config.js",
